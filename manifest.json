{
  "manifest_version": 2,
  "name": "Google Account Switcher",
  "version": "1.0",
  "description": "Automatically sets the authuser parameter on Google services to switch between accounts.",
  "browser_specific_settings": {
    "gecko": {
      "id": "google-account-switcher@peterullrich.com",
      "update_url": "https://raw.githubusercontent.com/PJUllrich/google-account-select-extension/main/updates.json",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["webRequest", "webRequestBlocking", "storage", "activeTab", "*://*.google.com/*"],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "Google Account Switcher",
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
